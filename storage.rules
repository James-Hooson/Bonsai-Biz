rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images: public read, admin-only write, capped at 5MB images
    match /products/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['jmhooson48@gmail.com', 'zenoasisnz@gmail.com']
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
